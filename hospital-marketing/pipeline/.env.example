# 실데이터 연동용 API 키. 이 파일을 .env로 복사해 값을 채우세요. .env는 커밋 금지.

# 공공데이터포털 (건강보험심사평가원 병원정보서비스 활용신청 후 발급)
DATA_GO_KR_SERVICE_KEY=

# 네이버 개발자센터 오픈 API (검색 > 지역)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# SGIS 통계지리정보서비스 (인구·상권 지표)
SGIS_CONSUMER_KEY=
SGIS_CONSUMER_SECRET=

# 네이버 검색광고(광고주) API — 절대 월 검색량·연관검색어 (키워드도구)
#   발급: 네이버 검색광고(searchad.naver.com) 로그인 → 도구 > API 사용 관리
#   - NAVER_AD_API_KEY     : 액세스 라이선스
#   - NAVER_AD_SECRET_KEY  : 비밀키 (서명 HMAC-SHA256)
#   - NAVER_AD_CUSTOMER_ID : 내 계정 CUSTOMER_ID (숫자)
#   광고 집행/과금 없이 키만 발급해도 키워드도구 조회 가능.
NAVER_AD_API_KEY=
NAVER_AD_SECRET_KEY=
NAVER_AD_CUSTOMER_ID=
